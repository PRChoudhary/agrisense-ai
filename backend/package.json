{
  "name": "agrisense-ai-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "postinstall": "prisma generate",
    "deploy:start": "prisma migrate deploy && node src/server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^4.24.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2"
  }
}
