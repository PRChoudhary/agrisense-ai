# ==========================================
# Backend Environment Variables (Railway / Render)
# ==========================================

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://agrisense-frontend.vercel.app

# Database (Provided automatically by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@containers-us-west-XX.railway.app:5432/railway

# JWT Authentication (Generate random strong strings for these)
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI Integration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Weather API
OPENWEATHER_API_KEY=your_openweather_key

# News API (Optional)
NEWS_API_KEY=your_newsapi_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
